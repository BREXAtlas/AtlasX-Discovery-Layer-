OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=llama3.1

# Anthropic (Claude) provider. Optional. Install with:
#   pip install -e ".[anthropic]"
ANTHROPIC_API_KEY=
# Leave blank to use the provider default (claude-opus-4-8).
ANTHROPIC_MODEL=
ANTHROPIC_MAX_TOKENS=4096
# Temperature is only supported on older Claude models. Leave blank for
# Opus 4.6+/Opus 4.7/Opus 4.8/Sonnet 5/Fable, which reject it.
ANTHROPIC_TEMPERATURE=

ATLASX_DEFAULT_PROVIDER=offline

