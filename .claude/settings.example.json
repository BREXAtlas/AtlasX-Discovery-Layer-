{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pytest:*)",
      "Bash(atlasx:*)",
      "Bash(python -m pytest:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/*.pdf)"
    ]
  },
  "env": {
    "ATLASX_DEFAULT_PROVIDER": "offline"
  }
}
