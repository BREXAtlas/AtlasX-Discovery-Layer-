project:
  name: sample_project
  description: Fictional demo project for AtlasX Discovery Layer.
  # Provider: offline (default), local, openai, or anthropic.
  # Providers other than offline are configured via environment variables
  # (see .env.example). Offline needs no key and no network.
  default_provider: offline

input:
  papers_dir: papers
  manifest: source_manifest.yaml

output:
  outputs_dir: outputs

runtime:
  preserve_uncertainty: true
  require_source_trace: true
  human_review_required: true

