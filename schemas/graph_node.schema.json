{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlasx/graph_node.schema.json",
  "title": "GraphNode",
  "type": "object",
  "required": ["node_id", "node_type", "label"],
  "properties": {
    "node_id": { "type": "string" },
    "node_type": {
      "type": "string",
      "enum": ["Paper", "Author", "Journal", "ResearchQuestion", "Entity", "Input", "Condition", "Mechanism", "Outcome", "EvidenceUnit", "Gap", "DiscoveryDirection", "Concept", "Claim"]
    },
    "label": { "type": "string" },
    "paper_id": { "type": ["string", "null"] },
    "source_trace": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "properties": { "type": "object" }
  }
}

