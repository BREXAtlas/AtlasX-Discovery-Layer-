{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlasx/graph_edge.schema.json",
  "title": "GraphEdge",
  "type": "object",
  "required": ["edge_id", "source_id", "target_id", "edge_type"],
  "properties": {
    "edge_id": { "type": "string" },
    "source_id": { "type": "string" },
    "target_id": { "type": "string" },
    "edge_type": {
      "type": "string",
      "enum": ["PAPER_ASKS_QUESTION", "PAPER_TESTS_ENTITY", "PAPER_APPLIES_INPUT", "INPUT_UNDER_CONDITION", "CLAIM_SUPPORTS_MECHANISM", "MECHANISM_ASSOCIATED_WITH_OUTCOME", "EVIDENCE_SUPPORTS_CLAIM", "PAPER_HAS_GAP", "GAP_POINTS_TO_DISCOVERY_DIRECTION", "CONCEPT_EQUIVALENT_TO", "CONCEPT_RELATED_TO", "PAPER_CONNECTS_TO_PAPER", "PAPER_CONTRADICTS_PAPER", "PAPER_PUBLISHED_IN", "AUTHOR_OF_PAPER"]
    },
    "label": { "type": "string" },
    "paper_id": { "type": ["string", "null"] },
    "source_trace": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": { "type": "string" }
  }
}

