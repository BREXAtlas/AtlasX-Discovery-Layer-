{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlasx/stemd.schema.json",
  "title": "STEMdAnalysis",
  "type": "object",
  "required": ["paper_id", "atom_id", "specificity", "translatability", "evidence", "mechanism_systems", "discovery_direction"],
  "properties": {
    "paper_id": { "type": "string" },
    "atom_id": { "type": "string" },
    "specificity": { "$ref": "#/$defs/dimension" },
    "translatability": { "$ref": "#/$defs/dimension" },
    "evidence": { "$ref": "#/$defs/dimension" },
    "mechanism_systems": { "$ref": "#/$defs/dimension" },
    "discovery_direction": { "$ref": "#/$defs/dimension" },
    "human_review_required": { "type": "boolean" }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "required": ["value", "rationale", "confidence", "source_trace"],
      "properties": {
        "value": { "type": "string" },
        "rationale": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_trace": { "type": "string" }
      }
    }
  }
}

